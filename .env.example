# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/tia

# Payload CMS — Secret for encrypting tokens (must be a long, complex string)
PAYLOAD_SECRET=your-very-long-complex-secret-string-here

# Resend — Email API key (T9: contact form)
RESEND_API_KEY=

# Revalidation — Secret token for webhook (T10)
REVALIDATION_SECRET=

# Vercel Blob — Storage token for media uploads (T11)
BLOB_READ_WRITE_TOKEN=

# Public — Site URL (exposed to client)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
